# Copia este archivo como .env y rellena los valores
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# La URL real de n8n no se expone en el frontend.
# En desarrollo, Vite reenvia /webhook y /webhook-test a n8n.

# Cliente usado por la demo del iframe
VITE_DEFAULT_CLIENT_ID=
VITE_DEFAULT_COMPANY_NAME=

# Credenciales del Super Admin (login por .env, máximo privilegio)
# Este usuario NO existe en Supabase Auth; tiene acceso total a todos los clientes.
VITE_SUPER_ADMIN_USER=
VITE_SUPER_ADMIN_PASS=
