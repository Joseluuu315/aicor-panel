      "parameters": {
        "jsCode": "const formatted = $('6. Formatear Todo').all().map(item => item.json);\nconst results = formatted.map(item => ({\n  url: item.url || '',\n  status: 'done',\n  chars: (item.contenido || '').length,\n  client_id: item.client_id || '',\n  company_name: item.company_name || ''\n}));\n\nreturn [{\n  json: {\n    ok: true,\n    client_id: results[0]?.client_id || '',\n    company_name: results[0]?.company_name || '',\n    total: results.length,\n    results\n  }\n}];"
