      "parameters": {
        "jsCode": "const source = $('3. Limpiar y Filtrar').item.json;\nconst contenidoRaw = $json.contenido || [];\nconst contenidoLimpio = contenidoRaw\n  .join(' ')\n  .replace(/<[^>]*>?/gm, '')\n  .replace(/\\s+/g, ' ')\n  .trim();\n\nreturn {\n  json: {\n    url: source.url || '',\n    rootUrl: source.rootUrl || '',\n    rootDomain: source.rootDomain || '',\n    executionId: source.executionId || '',\n    client_id: source.clientId || '',\n    company_name: source.companyName || '',\n    contenido: contenidoLimpio\n  }\n};"
