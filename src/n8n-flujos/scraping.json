    {
      "parameters": {
        "jsCode": "const allUrls = $json.urls || [];\nconst rootUrl = $json.rootUrl || $json.url || '';\nconst rootDomain = ($json.rootDomain || '').toLowerCase();\nconst executionId = $json.executionId || '';\nconst clientId = $json.clientId || '';\nconst companyName = $json.companyName || '';\n\nconst cleanUrls = [...new Set(allUrls)]\n  .map((href) => {\n    try { return new URL(String(href), rootUrl); } catch (e) { return null; }\n  })\n  .filter(Boolean)\n  .filter((u) => ['http:', 'https:'].includes(u.protocol))\n  .filter((u) => u.hostname.replace(/^www\\./, '').toLowerCase() === rootDomain)\n  .filter((u) => /\\.(com|es)$/.test(u.hostname.replace(/^www\\./, '').toLowerCase()))\n  .filter((u) => !u.hash)\n  .filter((u) => !u.href.match(/\\.(jpg|jpeg|png|gif|webp|svg|pdf|zip|rar|mp4|mp3)$/i))\n  .filter((u) => !u.href.includes('@'))\n  .slice(0, 25);\n\nreturn cleanUrls.map((u) => ({\n  json: { url: u.href, rootUrl, rootDomain, executionId, clientId, companyName }\n}));"
      },
