    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst body = raw.body ?? raw;\nconst rawUrls = body.urls ?? [];\nconst executionId = $execution?.id ?? Date.now().toString();\n\nconst clientId = String(body.client_id || body.clientId || '').trim();\nconst companyName = String(body.company_name || body.companyName || body.empresa || '').trim();\n\nif (!clientId) throw new Error('client_id es obligatorio');\nif (!companyName) throw new Error('company_name es obligatorio');\n\nconst urls = [...new Set((Array.isArray(rawUrls) ? rawUrls : [rawUrls])\n  .map(u => String(u).trim())\n  .filter(Boolean))];\n\nif (urls.length === 0) throw new Error('Debes enviar al menos una URL');\nif (urls.length > 2) throw new Error('Solo se permiten 2 URLs por cliente');\n\nconst normalized = urls.map((url) => {\n  let parsed;\n  try { parsed = new URL(url); } catch (e) { throw new Error(`URL no valida: ${url}`); }\n  if (!['http:', 'https:'].includes(parsed.protocol)) throw new Error(`Protocolo no permitido: ${url}`);\n  const domain = parsed.hostname.replace(/^www\\./, '').toLowerCase();\n  if (!/\\.(com|es)$/.test(domain)) throw new Error(`Solo se permiten dominios .com o .es: ${domain}`);\n  return { url: parsed.href, domain };\n});\n\nreturn normalized.map(({ url, domain }) => ({\n  json: { url, rootUrl: url, rootDomain: domain, executionId, clientId, companyName }\n}));"
      },
